{
  "name": "Binary Sunset — Orders Analytics",
  "entryPoints": ["src"],
  "entryPointStrategy": "expand",
  "out": "docs",
  "exclude": [
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "src/__tests__/**",
    "node_modules/**",
    "src/mocks/**",
    "src/vite-env.d.ts"
  ],
  "excludeExternals": true,
  "excludePrivate": false,
  "includeVersion": true,
  "readme": "none",
  "theme": "default",
  "searchInComments": true,
  "categorizeByGroup": true,
  "sort": ["source-order"]
}
